async function attemptLogin() {
    const pin = pinInput.value.trim();
    if (!pin) {
        showError("Please enter a Mission Code.");
        return;
    }
    try {
        // REMOVED 'worksheets/' folder from the path
        const response = await fetch(`${pin}.json`);
        if (!response.ok) throw new Error("Code not found. Did you type 'mol_s3'?");
        
        let data = await response.json();
        
        // SAFETY: Clean the keys in case of trailing spaces in the JSON file
        if (Array.isArray(data)) {
            data = data.map(obj => {
                const cleanObj = {};
                for (let key in obj) {
                    cleanObj[key.trim()] = obj[key];
                }
                return cleanObj;
            });
            allQuestions = data;
            startGame();
        } else {
            throw new Error("Invalid data format.");
        }
    } catch (err) {
        showError("Error: " + err.message);
    }
}
